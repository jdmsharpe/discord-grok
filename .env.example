# Environment variables example file - use as a template for your .env file

# Required: Discord bot token for your application
BOT_TOKEN=your_discord_bot_token

# Required: Comma-separated Discord guild IDs where slash commands should be registered
GUILD_IDS=your_guild_id_1,your_guild_id_2

# Required: xAI API key used for Grok requests
XAI_API_KEY=your_xai_api_key

# Optional: Comma-separated collection IDs used by /grok chat collections_search
# Set this to enable the built-in collections search tool for chat requests
# XAI_COLLECTION_IDS=collection_id_1,collection_id_2

# Optional: Inline JSON object of named remote MCP presets for /grok chat
# Each preset supports: url (required HTTPS), authorization_env_var (optional), allowed_tools (optional)
# XAI_MCP_PRESETS_JSON={"trusted_docs":{"url":"https://mcp.example.com/sse","allowed_tools":["search"]}}

# Optional: Path to a JSON file containing named remote MCP presets
# Use this instead of XAI_MCP_PRESETS_JSON if you prefer a separate config file
# XAI_MCP_PRESETS_PATH=./config/xai-mcp-presets.json

# Optional: Show cost and token usage embeds on Grok responses (default: true; accepts true/1/yes)
# Set this to false to hide pricing and usage details in Discord
# SHOW_COST_EMBEDS=true

# Optional: Path to a pricing YAML that overrides the bundled src/discord_grok/config/pricing.yaml
# Useful for pushing a vendor price change without waiting for a code release
# XAI_PRICING_PATH=./config/custom-pricing.yaml

# Optional: Logging format. "text" (default) for human-readable; "json" for structured JSON-lines
# Log records include a request_id that is bound per slash-command and on_message handler
# LOG_FORMAT=json
